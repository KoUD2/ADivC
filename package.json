{
  "name": "static-site-boilerplate",
  "version": "2.0.0",
  "author": "Zakhar Day",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https:///github.com/ZakharDay/static-site-boilerplate"
  },
  "bugs": {
    "url": "https://github.com/ZakharDay/static-site-boilerplate/issues"
  },
  "homepage": "https://github.com/ZakharDay/static-site-boilerplate#readme",
  "scripts": {
    "dev": "webpack serve --open --config webpack.dev.js",
    "watch": "webpack --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "postbuild": "rm -f docs/200.html && react-snap"
  },
  "reactSnap": {
    "source": "docs",
    "publicPath": "/",
    "navigationTimeout": 60000,
    "skipThirdPartyRequests": true,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "inlineCss": false,
    "crawl": false,
    "include": [
      "/",
      "/about.html",
      "/404.html",
      "/tutorials/index.html",
      "/tutorials/module-1/index.html",
      "/tutorials/module-2/index.html",
      "/tutorials/module-3/index.html",
      "/tutorials/module-4/index.html",
      "/tutorials/module-1/lesson-1-1.html",
      "/tutorials/module-1/lesson-1-2.html",
      "/tutorials/module-2/lesson-2-1.html",
      "/tutorials/module-2/lesson-2-2.html",
      "/tutorials/module-2/lesson-2-3.html",
      "/tutorials/module-2/lesson-2-4.html",
      "/tutorials/module-2/lesson-2-5.html",
      "/tutorials/module-2/lesson-2-6.html",
      "/tutorials/module-2/lesson-2-7.html",
      "/tutorials/module-2/lesson-2-8.html",
      "/tutorials/module-2/lesson-2-9.html",
      "/tutorials/module-2/lesson-2-10.html",
      "/tutorials/module-2/lesson-2-11.html",
      "/tutorials/module-2/lesson-2-12.html",
      "/tutorials/module-3/lesson-3-1.html",
      "/tutorials/module-3/lesson-3-2.html",
      "/tutorials/module-3/lesson-3-3.html",
      "/tutorials/module-3/lesson-3-4.html",
      "/tutorials/module-4/lesson-4-1.html",
      "/tutorials/module-4/lesson-4-2.html",
      "/tutorials/module-4/lesson-4-3.html",
      "/tutorials/module-4/lesson-4-4.html"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.1",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "html-webpack-partials-plugin": "^0.8.0",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.4",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.2.4",
    "react-refresh": "^0.14.0",
    "react-snap": "^1.23.0",
    "stream-browserify": "^3.0.0",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "webpack": "^5.101.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "classnames": "^2.5.1",
    "monaco-editor": "^0.44.0",
    "prismjs": "^1.30.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
